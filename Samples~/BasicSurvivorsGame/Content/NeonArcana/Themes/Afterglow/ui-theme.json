    "tutorialSteps":  [
                          {
                              "id":  "combat",
                              "title":  "Run The Circuit",
                              "lines":  [
                                            "Move with WASD or the left stick. Neon Pulse and later protocols fire automatically at nearby anomalies.",
                                            "Use Phase Step to cut through pressure, repel nearby constructs, and open a brief escape lane.",
                                            "Keep moving, harvest signal motes, and keep the anomaly field barely under control."
                                        ]
                          },
                          {
                              "id":  "experience",
                              "title":  "Harvest Signal Motes",
                              "lines":  [
                                            "Defeated anomalies drop signal motes. Move near them to pull them into your level circuit.",
                                            "Flux Sweep pickups and collector upgrades recover distant motes without changing their XP value.",
                                            "Streak rewards, arena clears, and signal pylons can seed extra pickups when you play actively."
                                        ]
                          },
                          {
                              "id":  "drafts",
                              "title":  "Compile A Loadout",
                              "lines":  [
                                            "Level-ups pause the circuit and offer protocols: weapons, passives, mutations, and ascensions.",
                                            "Rescan changes the cards, Purge removes one for the run, and Archive grants neon fragments.",
                                            "Open Loadout Matrix to compare current weapons, passives, relics, run data, and controls."
                                        ]
                          },
                          {
                              "id":  "threats",
                              "title":  "Sentinels And Sovereigns",
                              "lines":  [
                                            "Sentinels, Null Beacons, Hexframe Prime, and the Blacklight Sovereign keep health, bars, and offscreen tracking.",
                                            "Major anomalies drop recoverable caches, relic protocols, upgrade protocols, or class unlock rewards.",
                                            "Warnings, slam markers, and relay-call banners announce sharp spikes in circuit pressure."
                                        ]
                          },
                          {
                              "id":  "evolutions",
                              "title":  "Ascend Protocols",
                              "lines":  [
                                            "Ascensions need a ranked weapon path plus its matching passive; ready banners name the missing piece.",
                                            "Ascension picks trigger a payoff surge, signal-mote recall, and stronger weapon behavior.",
                                            "Multiple ascensions stack into a late-run Legend Surge."
                                        ]
                          },
                          {
                              "id":  "modes",
                              "title":  "Choose A Circuit",
                              "lines":  [
                                            "Neon Arcana Standard is the full 30-minute circuit with Sovereign rewards, victory, and endless continuation.",
                                            "Neon Arcana Sprint compresses the circuit into 5 minutes with quicker XP, early sentinels, and a fast climax.",
                                            "After victory or defeat, recompile the same circuit or return to protocol selection."
                                        ]
                          }
                      ],
